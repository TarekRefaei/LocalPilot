{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "out/test",
    "rootDir": "src/test",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node", "vscode", "mocha"],
    "noEmitOnError": true
  },
  "include": ["src/test/**/*.ts"]
}
