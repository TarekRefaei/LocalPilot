{
  "name": "localpilot",
  "displayName": "LocalPilot",
  "description": "LocalPilot MVP v0.1",
  "version": "0.0.1",
  "publisher": "tarekrefaei",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:localpilot.views.chat"
  ],
  "contributes": {
    "configuration": {
      "title": "LocalPilot",
      "properties": {
        "localpilot.backend.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Base URL of the LocalPilot backend (FastAPI)."
        },
        "localpilot.model": {
          "type": "string",
          "default": "local",
          "description": "Selected chat model identifier."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "localpilot",
        "name": "localpilot",
        "fullName": "LocalPilot",
        "description": "Local, private AI coding assistant",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localpilot",
          "title": "LocalPilot",
          "icon": "resources/icon-localpilot.svg"
        }
      ]
    },
    "views": {
      "localpilot": [
        {
          "id": "localpilot.views.chat",
          "name": "Chat",
          "type": "webview",
          "icon": "resources/icons/status.svg"
        },
        {
          "id": "localpilot.views.plans",
          "name": "Plans",
          "icon": "resources/icons/plans.svg"
        },
        {
          "id": "localpilot.views.act",
          "name": "Act",
          "icon": "resources/icons/act.svg"
        },
        {
          "id": "localpilot.views.indexing",
          "name": "Indexing",
          "icon": "resources/icons/indexing.svg"
        },
        {
          "id": "localpilot.views.status",
          "name": "Status",
          "icon": "resources/icons/status.svg"
        }
      ]
    },
    "commands": [
      { "command": "localpilot.helloWorld", "title": "LocalPilot: Hello World", "category": "LocalPilot" },
      { "command": "localpilot.showViews", "title": "LocalPilot: Show Views", "category": "LocalPilot" },
      { "command": "localpilot.focusChatInput", "title": "LocalPilot: Focus Chat Input", "category": "LocalPilot" },
      { "command": "localpilot.chat.transferToPlan", "title": "LocalPilot: Transfer to Plan", "category": "LocalPilot" },
      { "command": "localpilot.plan.create", "title": "LocalPilot: Create Plan", "category": "LocalPilot" },
      { "command": "localpilot.plan.update", "title": "LocalPilot: Update Plan", "category": "LocalPilot" },
      { "command": "localpilot.plan.delete", "title": "LocalPilot: Delete Plan", "category": "LocalPilot" },
      { "command": "localpilot.plan.step.add", "title": "LocalPilot: Add Step", "category": "LocalPilot" },
      { "command": "localpilot.plan.step.toggle", "title": "LocalPilot: Toggle Step", "category": "LocalPilot" },
      { "command": "localpilot.plan.step.moveUp", "title": "LocalPilot: Move Step Up", "category": "LocalPilot" },
      { "command": "localpilot.plan.step.moveDown", "title": "LocalPilot: Move Step Down", "category": "LocalPilot" },
      { "command": "localpilot.plan.step.delete", "title": "LocalPilot: Delete Step", "category": "LocalPilot" },
      { "command": "localpilot.act.dryRun", "title": "LocalPilot: Dry Run", "category": "LocalPilot" },
      { "command": "localpilot.act.approve", "title": "LocalPilot: Approve", "category": "LocalPilot" },
      { "command": "localpilot.act.apply", "title": "LocalPilot: Apply Changes", "category": "LocalPilot" },
      { "command": "localpilot.act.rollback", "title": "LocalPilot: Rollback", "category": "LocalPilot" },
      { "command": "localpilot.index.start", "title": "LocalPilot: Start Indexing", "category": "LocalPilot" },
      { "command": "localpilot.index.stop", "title": "LocalPilot: Stop Indexing", "category": "LocalPilot" },
      { "command": "localpilot.model.swap", "title": "LocalPilot: Swap Model", "category": "LocalPilot" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "localpilot.showViews", "when": "true" },
        { "command": "localpilot.focusChatInput", "when": "true" }
      ],
      "view/title": [
        { "command": "localpilot.plan.create", "when": "view == localpilot.views.plans", "group": "navigation@1" },
        { "command": "localpilot.index.start", "when": "view == localpilot.views.indexing && !localpilot.indexing.running", "group": "navigation@1" },
        { "command": "localpilot.index.stop", "when": "view == localpilot.views.indexing && localpilot.indexing.running", "group": "navigation@1" }
      ],
      "view/item/context": [
        { "command": "localpilot.plan.step.toggle", "when": "view == localpilot.views.plans && viewItem == plans.step", "group": "inline@1" },
        { "command": "localpilot.plan.step.add", "when": "view == localpilot.views.plans && viewItem == plans.plan", "group": "navigation@1" },
        { "command": "localpilot.plan.step.moveUp", "when": "view == localpilot.views.plans && viewItem == plans.step", "group": "navigation@2" },
        { "command": "localpilot.plan.step.moveDown", "when": "view == localpilot.views.plans && viewItem == plans.step", "group": "navigation@3" },
        { "command": "localpilot.plan.step.delete", "when": "view == localpilot.views.plans && viewItem == plans.step", "group": "navigation@4" }
      ]
    },
    "keybindings": [
      {
        "command": "localpilot.showViews",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "localpilot.focusChatInput",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci",
    "test:integration": "npm run compile && tsc -p ./tsconfig.integration.json && node ./out/test/runTest.js",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/mocha": "^10.0.6",
    "@types/vscode": "^1.88.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint": "^8.57.0",
    "mocha": "^10.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.1.1",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "~5.5.4",
    "ws": "^8.16.0",
    "@types/ws": "^8.5.10"
  }
}
